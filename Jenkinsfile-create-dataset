pipeline {
    agent {
        dockerfile {
            filename 'Dockerfile'
            dir '.'
            args '-u root -v /tmp:/tmp -e UV_CACHE_DIR=/tmp/uv-cache -e UV_PYTHON_INSTALL_DIR=/tmp/uv-python'
        } 
    }
    environment { 
        UV_CACHE_DIR = "${WORKSPACE}/.uv_cache" 
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Data Processing') {
            steps {
                sh 'uv run scripts/download_and_process.sh 10'
            }
        }
        stage('Artifact') {
            steps {
                archiveArtifacts artifacts: 'data/dataset.csv', fingerprint: true
            }
        }
    }   
}