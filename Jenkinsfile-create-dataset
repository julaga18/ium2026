pipeline {
    agent {
        dockerfile {
            filename 'Dockerfile'
            dir '.'
            args '-u root -v /tmp:/tmp -e UV_CACHE_DIR=/tmp/uv-cache -e UV_PYTHON_INSTALL_DIR=/tmp/uv-python'
        } 
    }
    environment { 
        UV_CACHE_DIR = "/tmp/uv-cache"
        UV_PYTHON_INSTALL_DIR = "/tmp/uv-python"
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Data Processing') {
            steps {
                echo "Uruchamiam przygotowanie danych (Python)..."
                sh 'uv run python3 scripts/create_dataset.py'
            }
        }
        stage('Artifact') {
            steps {
                archiveArtifacts artifacts: 'data/dataset.csv', fingerprint: true
            }
        }
    }   
}