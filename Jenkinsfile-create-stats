pipeline {
    agent {
        docker {
            image 'julaga18/ium:2.0' 
            alwaysPull true
            args '-u root -v /tmp:/tmp -e UV_CACHE_DIR=/tmp/uv-cache -e UV_PYTHON_INSTALL_DIR=/tmp/uv-python'
        }
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Calculate Stats') {
            steps {
                echo "Obliczanie statystyk i normalizacja..."
                sh 'uv run python3 scripts/process_data.py'
            }
        }
        stage('Artifact') {
            steps {
                archiveArtifacts artifacts: 'data/dataset.csv', fingerprint: true
            }
        }
    }
}